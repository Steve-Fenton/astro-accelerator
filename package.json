{
    "version": "7.0.6",
    "author": "Steve Fenton",
    "name": "astro-accelerator",
    "description": "A super-lightweight, accessible, SEO-friendly starter project for Astro",
    "keywords": [
        "astro",
        "themes"
    ],
    "type": "module",
    "packageManager": "pnpm@10.22.0",
    "engines": {
        "node": ">=24",
        "pnpm": ">=10"
    },
    "homepage": "https://astro.stevefenton.co.uk/",
    "bugs": "https://github.com/Steve-Fenton/astro-accelerator/issues",
    "license": "(Apache-2.0)",
    "repository": {
        "url": "https://github.com/Steve-Fenton/astro-accelerator"
    },
    "scripts": {
        "refresh": "npm version patch && pnpm update --latest && pnpm test",
        "update-node": "bash -c 'source $NVM_DIR/nvm.sh && nvm install --lts && npm install -g pnpm'",
        "img": "node ./src/themes/accelerator/utilities/img.mjs",
        "dev": "node ./src/themes/accelerator/utilities/img.mjs && astro dev",
        "stats": "node ./src/themes/accelerator/utilities/stats.mjs",
        "spellcheck": "git fetch origin main:refs/remotes/origin/main && git diff origin/main --name-only --diff-filter=ACMRTUXB | cspell --no-must-find-files --file-list stdin",
        "test": "astro build && npx playwright install chromium --with-deps && npx playwright test",
        "crawl": "linkinator ./dist --skip \"^(?!http://localhost)\" --skip \"/404/\" --recurse  --verbosity error",
        "build": "astro build",
        "preview": "astro preview",
        "astro": "astro",
        "dts": "tsc ./tests/locate-content.js ./tests/locate-navigation.js ./tests/locate-search.js --allowJs --declaration --emitDeclarationOnly"
    },
    "dependencies": {
        "@astrojs/markdown-remark": "^7.2.1",
        "@astrojs/mdx": "^7.1.0",
        "@img/sharp-linux-x64": "^0.35.3",
        "astro": "^7.0.7",
        "astro-accelerator-utils": "^0.3.98",
        "csv": "^6.6.1",
        "hast-util-from-selector": "^3.0.1",
        "html-to-text": "^10.0.0",
        "keyword-extractor": "^0.0.28",
        "optional": "^0.1.4",
        "remark-directive": "^4.0.0",
        "sharp": "^0.35.3"
    },
    "devDependencies": {
        "@playwright/test": "^1.61.1",
        "cspell": "^10.0.1",
        "glob": "^13.0.6",
        "linkinator": "^7.6.1"
    },
    "files": [
        "pnpm-workspace.yaml",
        "env.d.ts",
        "tsconfig.json",
        "astro.config.mjs",
        "sample/*",
        "sample/**/*",
        "src/config.ts",
        "src/content.config.ts",
        "src/pages/404.md",
        "src/pages/index.md",
        "src/pages/search.md",
        "src/pages/rss.xml.ts",
        "src/pages/articles/*.astro",
        "src/pages/articles/*.ts",
        "src/pages/authors/**/*.astro",
        "src/pages/category/**/*.astro",
        "src/pages/category/**/*.astro",
        "src/pages/events/**/*.astro",
        "src/pages/tag/**/*.astro",
        "src/pages/tag/**/*.astro",
        "src/pages/search.json.ts",
        "src/pages/sitemap.xml.ts",
        "src/pages/report/*",
        "src/pages/report/oldest-content/*",
        "src/layouts/*",
        "src/themes/accelerator/components/*",
        "src/themes/accelerator/layouts/*",
        "src/themes/accelerator/utilities/*",
        "src/data/*",
        "public/img/astro-lighthouse.png",
        "public/icons/**/*",
        "public/css/*",
        "public/js/*"
    ],
    "pnpm": {
        "overrides": {
            "postcss@<8.4.31": ">=8.4.31",
            "vite@<=5.0.11": ">=5.0.12",
            "zod@<=3.22.2": ">=3.22.3"
        }
    }
}
